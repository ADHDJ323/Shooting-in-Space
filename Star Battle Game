<!DOCTYPE html> 
<html>
<head>
<meta charset="UTF-8">
<title>Star Battle Game</title>

<style>
body{
    margin:0;
    background:rgb(0, 0, 0);
    overflow:hidden;
    color:rgb(120, 94, 45);
    font-family:Arial;
}

#ui{
    position:absolute;
    top:10px;
    left:10px;
    font-size:18px;
}

#mobileControls{
    position:absolute;
    bottom:20px;
    width:100%;
    text-align:center;
}

.btn{
    font-size:25px;
    padding:10px 20px;
    margin:5px;
}
</style>
</head>

<body>

<div id="ui">
Score: <span id="score">0</span>
<br>
Lives: <span id="lives">66</span>
<br>
High Score: <span id="high"></span>
</div>

<canvas id="game"></canvas>

<div id="mobileControls">
<button class="btn" onclick="moveLeft()">⬅️</button>
<button class="btn" onclick="shoot()">🔫</button>
<button class="btn" onclick="moveRight()">➡️</button>
</div>

<script>

const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let score = 0;
let lives = 66;

let highScore = localStorage.getItem("spaceHigh") || 0;
document.getElementById("high").innerText = highScore;

const player = {
    x: canvas.width/2,
    y: canvas.height-80,
    size:70
};

let bullets=[];
let enemies=[];
let stars=[];
let explosions=[];
let boss=null;

const laserSound = new Audio("https://actions.google.com/sounds/v1/science_fiction/laser_1.ogg");
const boomSound = new Audio("https://actions.google.com/sounds/v1/explosions/explosion.ogg");

for(let i=0;i<100;i++){
    stars.push({
        x:Math.random()*canvas.width,
        y:Math.random()*canvas.height,
        speed:2+Math.random()*3
    });
}

function spawnEnemy(){

    if(score>0 && score%50===0 && !boss){
        boss={
            x:canvas.width/2-100,
            y:50,
            w:200,
            h:60,
            hp:150
        };
        return;
    }

    enemies.push({
        x:Math.random()*canvas.width,
        y:-40,
        size:40,
        speed:2+Math.random()*2
    });
}

setInterval(spawnEnemy,1000);

document.addEventListener("keydown",e=>{
    if(e.key==="ArrowLeft") player.x-=30;
    if(e.key==="ArrowRight") player.x+=30;
    if(e.key===" ") shoot();
});

function moveLeft(){player.x-=30}
function moveRight(){player.x+=30}

function shoot(){

    bullets.push({
        x:player.x,
        y:player.y
    });

    laserSound.currentTime=0;
    laserSound.play();
}

function update(){

    stars.forEach(s=>{
        s.y+=s.speed;

        if(s.y>canvas.height){
            s.y=0;
            s.x=Math.random()*canvas.width;
        }
    });

    bullets.forEach((b,i)=>{
        b.y-=10;
        if(b.y<0) bullets.splice(i,1);
    });

    enemies.forEach((e,ei)=>{

        e.y+=e.speed;

        if(e.y>canvas.height){
            enemies.splice(ei,1);
            lives--;
        }

        bullets.forEach((b,bi)=>{

            if(
                b.x<e.x+e.size &&
                b.x>e.x &&
                b.y<e.y+e.size &&
                b.y>e.y
            ){

                explosions.push({x:e.x,y:e.y,life:20});

                boomSound.currentTime=0;
                boomSound.play();

                enemies.splice(ei,1);
                bullets.splice(bi,1);

                score++;

                document.getElementById("score").innerText=score;
            }

        });
    });

    if(boss){

        bullets.forEach((b,bi)=>{

            if(
                b.x>boss.x &&
                b.x<boss.x+boss.w &&
                b.y>boss.y &&
                b.y<boss.y+boss.h
            ){

                boss.hp--;
                bullets.splice(bi,1);

                if(boss.hp<=0){
                    explosions.push({x:boss.x+80,y:boss.y,life:60});
                    score+=20;
                    boss=null;
                }
            }

        });

    }

    explosions.forEach((ex,i)=>{
        ex.life--;
        if(ex.life<=0) explosions.splice(i,1);
    });

    document.getElementById("lives").innerText=lives;

    if(lives<=0){
        if(score>highScore){
            localStorage.setItem("spaceHigh",score);
        }
        alert("Game Over!");
        location.reload();
    }
}

function draw(){

    ctx.fillStyle="black";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    ctx.fillStyle="white";

    stars.forEach(s=>{
        ctx.fillRect(s.x,s.y,2,2);
    });

    ctx.fillStyle="cyan";

    ctx.beginPath();
    ctx.moveTo(player.x,player.y);
    ctx.lineTo(player.x-20,player.y+40);
    ctx.lineTo(player.x+20,player.y+40);
    ctx.fill();

    ctx.fillStyle="red";

    bullets.forEach(b=>{
        ctx.fillRect(b.x,b.y,4,10);
    });

    ctx.fillStyle="lime";

    enemies.forEach(e=>{
        ctx.fillRect(e.x,e.y,e.size,e.size);
    });

    if(boss){
        ctx.fillStyle="purple";
        ctx.fillRect(boss.x,boss.y,boss.w,boss.h);

        ctx.fillStyle="white";
        ctx.fillText("BOSS HP: "+boss.hp,boss.x,boss.y-10);
    }

    explosions.forEach(ex=>{
        ctx.beginPath();
        ctx.arc(ex.x,ex.y,30 .life,0,Math.PI*2);
        ctx.strokeStyle="orange";
        ctx.stroke();
    });

}

function loop(){
    update();
    draw();
    requestAnimationFrame(loop);
}

loop();

</script>
</body>
</html>
 
